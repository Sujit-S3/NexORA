# NexORA v1.0.0 Frontend Environment Variables
# Copy this file to .env.local and fill in values before running/deploying.
# Lines marked REQUIRED must be set for the app to function correctly.
# Lines marked OPTIONAL enable additional features when set.

# ── API URL ──────────────────────────────────────────────────────────────────
# REQUIRED: Points the frontend at the backend API
# Development:  http://localhost:5000/api
# Production:   https://your-nexora-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── App Metadata ──────────────────────────────────────────────────────────────
VITE_APP_NAME=NexORA
VITE_APP_VERSION=1.0.0

# ── PostHog Analytics ─────────────────────────────────────────────────────────
# OPTIONAL: Analytics are silently disabled if this key is not set (no crash).
# Get your project API key at https://posthog.com/
# Use separate projects for development and production.
# Development key:  phc_dev_...
# Production key:   phc_prod_...
VITE_POSTHOG_KEY=phc_your_posthog_project_api_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com
