# NexORA v1.0.0 Backend Environment Variables
# Copy this file to .env and fill in all values before deployment.
# Lines marked REQUIRED must be set — the server will refuse to start without them.
# Lines marked OPTIONAL can be omitted if you are not using that feature.

# ── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development          # REQUIRED: development | production
PORT=5000                     # REQUIRED

# ── MongoDB ──────────────────────────────────────────────────────────────────
# REQUIRED: Get your connection string from MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/NexORA?retryWrites=true&w=majority

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED: Use strong random secrets (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_generate_with_crypto
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars_different_from_above
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS / Client URL ─────────────────────────────────────────────────────────
# REQUIRED: Used for CORS policy, password reset URLs, and welcome email links
# Development:  http://localhost:5173
# Production:   https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ── Cloudinary (Image Uploads) ────────────────────────────────────────────────
# REQUIRED: Create a free account at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── AI Provider (Google Gemini) ────────────────────────────────────────────────
# REQUIRED: Get your API key at https://aistudio.google.com/
# Used for: AI Concierge (Flash), Admin AI Studio (Pro), comparisons
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI Catalog Versioning ─────────────────────────────────────────────────────
# Increment this when products/prices/inventory change to invalidate the AI cache
CATALOG_VERSION=1

# ── Email Service (Resend) ────────────────────────────────────────────────────
# REQUIRED in production: Get your API key at https://resend.com/
# In development: emails are logged to console — no key needed
# In production: missing key = password reset emails silently fail
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=NexORA <noreply@yourdomain.com>

# ── Feature Flags (optional overrides) ───────────────────────────────────────
# v1.0.0 Launch State: COD only. Stripe/PayPal disabled pending full lifecycle testing.
# ENABLE_STRIPE=false
# ENABLE_PAYPAL=false
